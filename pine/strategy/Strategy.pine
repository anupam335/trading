// Strategy.pine - Strategy combining engines into an executable strategy
// @version=5
// Release: v1.0
strategy("AI-NIFTY-Predictor-Pro Strategy (v1.0)", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=10)

// Inputs for tuning
fast_len = input.int(14, "Fast EMA", minval=1)
slow_len = input.int(50, "Slow EMA", minval=1)
rsi_len = input.int(14, "RSI Length", minval=1)
obv_ma_len = input.int(20, "OBV MA Length", minval=1)
setup_ema = input.int(20, "Setup EMA Length", minval=1)
atr_len = input.int(14, "ATR Length", minval=1)

// Signals: local implementation of Core scoring
ema_fast = ta.ema(close, fast_len)
ema_slow = ta.ema(close, slow_len)
trend = ema_fast > ema_slow ? 1 : ema_fast < ema_slow ? -1 : 0

rsi = ta.rsi(close, rsi_len)
mom = rsi > 60 ? 1 : rsi < 40 ? -1 : 0

obv = ta.cum(change(close) > 0 ? volume : change(close) < 0 ? -volume : 0)
obv_ma = ta.sma(obv, obv_ma_len)
vol = obv > obv_ma ? 1 : obv < obv_ma ? -1 : 0

setup = close > ta.ema(close, setup_ema) ? 1 : -1
risk = ta.atr(atr_len) < ta.sma(ta.atr(atr_len),50) ? 1 : -1

confidence = trend + mom + vol + setup + risk

// Entry/exit thresholds (exposed for tuning)
entry_threshold = input.int(3, "Entry Confidence Threshold")
exit_threshold = input.int(0, "Exit Confidence Threshold")

long_entry = confidence >= entry_threshold
long_exit = confidence <= exit_threshold

if (long_entry)
    strategy.entry("VEDA Long", strategy.long)

if (long_exit)
    strategy.close("VEDA Long")

// Plot confidence and signals
plot(confidence, title="Confidence", color=color.fuchsia)
plotshape(long_entry, title="Entry", style=shape.arrowup, location=location.belowbar, color=color.green)
plotshape(long_exit, title="Exit", style=shape.arrowdown, location=location.abovebar, color=color.red)
